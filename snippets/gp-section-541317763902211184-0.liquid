      {%- assign colorArraysString = "" -%}
      {%- assign imageUrlsString = "" -%}

      {% for optionValue in swatch.optionValues %}
        {%- assign labelsString = labelsString | append: optionValue.label | append: '|||' -%}
        {%- assign colorsJoined = optionValue.colors | join: '|||' -%}
        {%- assign colorArraysString = colorArraysString | append: colorsJoined | append: '|||' -%}
        {%- assign imageUrlsString = imageUrlsString | append: optionValue.imageUrl | append: '|||' -%}
      {% endfor %}

      {%- assign labels = labelsString | split: '|||' | slice: 0, labelsString.size -%}
      {%- assign colorStrings = colorArraysString | split: '|||' | slice: 0, colorArraysString.size -%}
      {%- assign imageUrls = imageUrlsString | split: '|||' | slice: 0, imageUrlsString.size -%}

      {% if optionTitle == option.name %}
