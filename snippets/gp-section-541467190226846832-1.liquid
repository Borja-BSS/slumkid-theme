        name="{{product.id}}-options-{{option.name | escape}}"
        id="{{product.id}}-g1uGqIbOwK-{{option.name | escape}}-{{option.position}}-{{ forloop.index }}"
        value="{{value | escape}}"
        type="radio"
        class="gp-sr-only gp-absolute gp-bottom-0 gp-right-0"
