    <div class="price-block">
      <span class="price-main" id="priceMain">129.90 CHF</span>
      <span class="price-label" id="priceLabel">Storm Jacket</span>
    </div>

    <div class="size-row">
      <span class="size-label">Taille — <span id="sizeVal">M</span></span>
      <span class="size-guide">Guide des tailles</span>
    </div>
    <div class="size-grid">
      <button class="size-btn" onclick="pick(this)">XS</button>
      <button class="size-btn" onclick="pick(this)">S</button>
      <button class="size-btn active" onclick="pick(this)">M</button>
      <button class="size-btn" onclick="pick(this)">L</button>
      <button class="size-btn" onclick="pick(this)">XL</button>
      <button class="size-btn sold">XXL</button>
    </div>

    <div class="buy-stack">
      <button class="btn-primary" onclick="cartAndRedirect('https://slumkid.myshopify.com/checkout')">Ajouter au panier</button>
      <a href="https://slumkid.myshopify.com/checkout" class="btn-glass" style="text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;">Acheter maintenant</a>
      <button class="btn-glass" onclick="openSizeQuiz()" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        Find My Size
      </button>
    </div>

    <div class="delivery">
      <div class="dot-green"></div>
      En stock · Livraison offerte dès 80 CHF · Expédition 24–48 h
    </div>
  </div>

</section>

