    <p class="product-tagline">Imperméable · Réflectif · Technical</p>

    <div class="type-tabs">
      <button class="type-tab active" onclick="switchTab(this,'jacket')">Jacket</button>
      <button class="type-tab" onclick="switchTab(this,'jogger')">Jogger</button>
      <button class="type-tab" onclick="switchTab(this,'set')">Set Complet</button>
