<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: #fff;
      color: #000;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem;
    }

    .password-logo {
      width: 220px;
      max-width: 80vw;
      margin-bottom: 2.5rem;
    }

    .password-form {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      width: 100%;
      max-width: 360px;
    }

    .password-form input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      background: transparent;
      border: 1px solid #000;
      color: #000;
      font-size: 1rem;
      letter-spacing: 0.05em;
      outline: none;
      text-align: center;
    }

    .password-form input[type="password"]::placeholder {
      color: #999;
    }

    .password-form button {
      width: 100%;
      padding: 0.75rem 1rem;
      background: #000;
      color: #fff;
      border: none;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .password-form button:hover {
      background: #222;
    }

    .password-message {
      margin-top: 1.5rem;
      font-size: 0.85rem;
      color: #666;
      text-align: center;
      letter-spacing: 0.05em;
    }
  </style>
</head>
<body>
  <img src="{{ 'logo-slumkid.png' | asset_url }}" alt="{{ shop.name }}" class="password-logo" />

  {{ content_for_layout }}

  {%- if shop.password_message != blank -%}
    <p class="password-message">{{ shop.password_message }}</p>
  {%- endif -%}
</body>
</html>
