<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #ffffff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: Helvetica, Arial, sans-serif;
    }
    img.logo { width: 280px; max-width: 80vw; margin-bottom: 3rem; }
    .form { display: flex; flex-direction: column; align-items: center; gap: 1rem; width: 320px; max-width: 90vw; }
    .email-row { display: flex; width: 100%; gap: 0; }
    .email-row input { flex: 1; padding: 14px 16px; border: 1px solid #000; font-size: 14px; letter-spacing: 0.05em; outline: none; }
    .email-row button { padding: 14px 20px; background: #000; color: #fff; border: none; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; }
    .password-section { display: flex; align-items: center; gap: 8px; margin-top: 0.5rem; }
    .password-section span { font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: #000; }
    .password-section input { padding: 10px 14px; border: 1px solid #ccc; font-size: 13px; outline: none; }
  </style>
</head>
<body>
  <img class="logo" src="{{ 'logo-slumkid.png' | asset_url }}" alt="{{ shop.name }}" width="280" height="80">
  {{ content_for_layout }}
</body>
</html>