<style>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --white: #ffffff; --black: #0a0a0a; --gray: #86868b;
  --light: #f5f5f7; --mid: #e0e0e0;
  --font: -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  --ease: cubic-bezier(0.4,0,0.2,1);
  --radius-btn: 980px;
}
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: var(--font); background: var(--white); color: var(--black); overflow-x: hidden; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; width: 100%; z-index: 200; height: 52px;
  background: rgba(10,10,10,0.0); backdrop-filter: blur(0px);
  border-bottom: 1px solid transparent;
  display: flex; align-items: center; justify-content: space-between; padding: 0 2.4rem;
  transition: background 0.4s, backdrop-filter 0.4s, border-color 0.4s;
}
nav.scrolled {
  background: rgba(10,10,10,0.75); backdrop-filter: saturate(180%) blur(20px);
  border-color: rgba(255,255,255,0.07);
}
.nav-logo { font-size: 0.95rem; font-weight: 800; letter-spacing: 0.18em; color: var(--white); text-decoration: none; text-transform: uppercase; }
.nav-back { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; color: rgba(255,255,255,0.6); text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
.nav-back:hover { color: var(--white); }

/* ══ HERO FULLSCREEN ══ */
.hero {
  height: 100vh; position: relative; overflow: hidden;
  display: flex; align-items: flex-end;
}
.hero-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center 30%;
}
.hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.1) 100%);
}
.hero-content {
  position: relative; z-index: 2; padding: 0 5rem 6rem;
  max-width: 800px;
}
.hero-eyebrow {
  font-size: 0.62rem; letter-spacing: 0.3em; font-weight: 600;
  color: rgba(255,255,255,0.45); text-transform: uppercase; margin-bottom: 1.2rem;
  display: flex; align-items: center; gap: 1rem;
}
.hero-eyebrow::before {
  content: ''; width: 40px; height: 1px; background: rgba(255,255,255,0.3);
}
.hero-title {
  font-size: clamp(3.5rem, 9vw, 9rem); font-weight: 900;
  letter-spacing: -0.04em; line-height: 0.88; text-transform: uppercase;
  color: var(--white); margin-bottom: 2rem;
}
.hero-title span { display: block; }
.hero-scroll {
  display: flex; align-items: center; gap: 0.8rem;
  font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}
.scroll-line {
  width: 40px; height: 1px; background: rgba(255,255,255,0.3);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse { 0%,100%{width:40px} 50%{width:70px} }

/* ══ QUOTE SECTION ══ */
.quote-section {
  background: var(--black); padding: 8rem 5rem;
  display: flex; align-items: center; justify-content: center;
  text-align: center; min-height: 60vh;
}
.quote-inner { max-width: 900px; }
.quote-mark {
  font-size: 6rem; line-height: 0.5; color: rgba(255,255,255,0.08);
  font-family: Georgia, serif; margin-bottom: 2rem; display: block;
}
.quote-text {
  font-size: clamp(1.4rem, 3vw, 2.4rem); font-weight: 800;
  letter-spacing: -0.03em; line-height: 1.2; text-transform: uppercase;
  color: var(--white); margin-bottom: 2rem;
}
.quote-text em { font-style: italic; color: rgba(255,255,255,0.5); font-weight: 300; }
.quote-from {
  font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
  color: rgba(255,255,255,0.3); font-weight: 500;
}

/* ══ MOSAIC SECTIONS ══ */
.mosaic-1 {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 100vh;
}
.mosaic-img {
  overflow: hidden; position: relative;
}
.mosaic-img img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.8s var(--ease);
}
.mosaic-img:hover img { transform: scale(1.04); }
.mosaic-text {
  background: var(--white); display: flex; flex-direction: column;
  justify-content: center; padding: 6rem 5rem;
}
.mosaic-text.dark { background: var(--black); }
.mosaic-eyebrow {
  font-size: 0.6rem; letter-spacing: 0.25em; font-weight: 700;
  text-transform: uppercase; color: var(--gray); margin-bottom: 1.2rem;
  display: flex; align-items: center; gap: 0.8rem;
}
.mosaic-eyebrow::before {
  content: ''; width: 30px; height: 1px; background: var(--gray);
}
.mosaic-title {
  font-size: clamp(2.2rem, 4vw, 3.8rem); font-weight: 900;
  letter-spacing: -0.04em; line-height: 0.92; text-transform: uppercase;
  margin-bottom: 2rem;
}
.mosaic-title.white { color: var(--white); }
.mosaic-body {
  font-size: 0.9rem; color: rgba(0,0,0,0.6); line-height: 1.8;
  letter-spacing: 0.01em; max-width: 480px;
}
.mosaic-body.white { color: rgba(255,255,255,0.55); }

/* ══ FULL BANNER TEXT ══ */
.full-text-banner {
  background: var(--black); padding: 10rem 5rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 8rem;
  align-items: center;
}
.ftb-left { }
.ftb-title {
  font-size: clamp(3rem, 6vw, 6rem); font-weight: 900;
  letter-spacing: -0.04em; line-height: 0.88;
  text-transform: uppercase; color: var(--white);
}
.ftb-right { }
.ftb-body {
  font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.9;
  letter-spacing: 0.01em;
}
.ftb-body strong { color: var(--white); font-weight: 700; }

/* ══ SPLIT PHOTO ══ */
.split-section {
  display: grid; grid-template-columns: 1fr 1fr; height: 80vh;
}
.split-img {
  overflow: hidden; position: relative;
}
.split-img img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.8s var(--ease);
}
.split-img:hover img { transform: scale(1.04); }
.split-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
  display: flex; align-items: flex-end; padding: 2.5rem;
}
.split-label {
  font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: rgba(255,255,255,0.5); font-weight: 600;
}

/* ══ MANIFESTO ══ */
.manifesto {
  background: var(--light); padding: 10rem 5rem;
  text-align: center;
}
.manifesto-pre {
  font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--gray); margin-bottom: 3rem; display: block;
}
.manifesto-lines { max-width: 800px; margin: 0 auto; }
.manifesto-line {
  font-size: clamp(1.5rem, 3.5vw, 3rem); font-weight: 900;
  letter-spacing: -0.03em; line-height: 1.1; text-transform: uppercase;
  color: var(--black); padding: 0.6rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  opacity: 0; transform: translateY(20px);
  animation: fadeUp 0.6s var(--ease) forwards;
}
.manifesto-line:last-child { border-bottom: none; }
@keyframes fadeUp { to { opacity:1; transform:translateY(0); } }

/* ══ CLOSING CTA ══ */
.cta-section {
  background: var(--black); padding: 10rem 5rem;
  text-align: center; position: relative; overflow: hidden;
}
.cta-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  opacity: 0.2;
}
.cta-content { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
.cta-eyebrow {
  font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase;
  color: rgba(255,255,255,0.35); margin-bottom: 1.5rem; display: block;
}
.cta-title {
  font-size: clamp(3rem, 7vw, 7rem); font-weight: 900;
  letter-spacing: -0.04em; line-height: 0.9; text-transform: uppercase;
  color: var(--white); margin-bottom: 3rem;
}
.cta-sub {
  font-size: 0.9rem; color: rgba(255,255,255,0.4); line-height: 1.8;
  margin-bottom: 3rem; max-width: 480px; margin-left: auto; margin-right: auto;
}
.btn-white {
  display: inline-flex; align-items: center;
  background: var(--white); color: var(--black);
  border: none; border-radius: var(--radius-btn);
  padding: 0.85rem 2.2rem; font-family: var(--font);
  font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; cursor: pointer;
  transition: opacity 0.2s; text-decoration: none;
}
.btn-white:hover { opacity: 0.85; }

/* FOOTER */
.page-footer {
  background: var(--black); color: var(--white);
  padding: 2rem 2.5rem; display: flex; align-items: center; justify-content: space-between;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.foot-logo { font-size: 0.85rem; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; }
.foot-copy { font-size: 0.68rem; color: rgba(255,255,255,0.3); letter-spacing: 0.06em; }

@media (max-width: 900px) {
  .hero-content { padding: 0 2rem 5rem; }
  .quote-section { padding: 5rem 2rem; }
  .mosaic-1 { grid-template-columns: 1fr; }
  .mosaic-text { padding: 4rem 2rem; }
  .full-text-banner { grid-template-columns: 1fr; gap: 3rem; padding: 6rem 2rem; }
  .split-section { grid-template-columns: 1fr; height: auto; }
  .split-img { height: 60vw; }
  .manifesto { padding: 6rem 2rem; }
  .cta-section { padding: 6rem 2rem; }
  nav { padding: 0 1.2rem; }
}

</style>
<nav id="mainNav">
  <a class="nav-back" href="/">&#8592; Retour</a>
  <a class="nav-logo" href="/">KID</a>
</nav>

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Slum Kid — Notre Histoire</p>
    <h1 class="hero-title">
      <span>FROM</span>
      <span>SLUM</span>
      <span>TO FASHION</span>
    </h1>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
      Scroll
    </div>
  </div>
</section>

<!-- ══ QUOTE ══ -->
<section class="quote-section">
  <div class="quote-inner">
    <span class="quote-mark">"</span>
    <p class="quote-text">
      On vient pas forcément des bidonvilles<br>
      mais crois moi qu'on a la même dalle qu'eux.
      <em> La même faim. Le même feu.</em>
    </p>
    <span class="quote-from">— Slum Kid</span>
  </div>
</section>

<!-- ══ MOSAIC 1 — img gauche, texte droite ══ -->
<section class="mosaic-1">
  <div class="mosaic-img">
    <img id="img1" alt="Slum Kid">
  </div>
  <div class="mosaic-text">
    <p class="mosaic-eyebrow">Une mentalité</p>
    <h2 class="mosaic-title">LA DALLE<br>DES<br>BIDONVILLES</h2>
    <p class="mosaic-body">
      Slum kid c'est une marque de vêtement mais avant tout c'est une mentalité inspirée des enfants des bidonvilles. Un petit qui part de rien, de zéro et qui veut arriver au sommet. Qui veut s'en sortir coûte que coûte. Pour lui. Pour les siens. Un rêveur qui passe à l'action.
    </p>
  </div>
</section>

<!-- ══ MOSAIC 2 — texte gauche (dark), img droite ══ -->
<section class="mosaic-1" style="direction:rtl">
  <div class="mosaic-img" style="direction:ltr">
    <img id="img2" alt="Slum Kid">
  </div>
  <div class="mosaic-text dark" style="direction:ltr">
    <p class="mosaic-eyebrow" style="color:rgba(255,255,255,0.35)">Une communauté</p>
    <h2 class="mosaic-title white">POUR CEUX<br>QUI ONT<br>LA MÊME FAIM</h2>
    <p class="mosaic-body white">
      On fait pas partie de ceux qui disent avoir des rêves mais qui font rien pour les réaliser. Slum kid c'est pour ceux qui ont la même mentalité, la même dalle, la même envie, la même détermination, les mêmes ambitions. On a créé slum kid pour être entourés de personnes comme nous.
    </p>
  </div>
</section>

<!-- ══ FULL TEXT BANNER ══ -->
<section class="full-text-banner">
  <div class="ftb-left">
    <h2 class="ftb-title">FROM<br>SLUM<br>TO ANY<br>THING</h2>
  </div>
  <div class="ftb-right">
    <p class="ftb-body">
      Y'a une phrase qu'on dit souvent : <strong>From Slum to Fashion</strong>. Du bidonville à la mode. C'est une phrase qui nous correspond. Mais c'est une phrase qui peut correspondre à chacun.
      <br><br>
      Parce qu'un slum kid ça appartient pas qu'au statut, c'est une mentalité. Ça peut être <strong>from slum to football</strong>, from slum to médecin, from slum to n'importe quoi.
      <br><br>
      Peu importe ce que tu veux faire, peu importe ton rêve. Notre rêve à nous c'est la mode. Donc <strong>from slum to fashion</strong>.
    </p>
  </div>
</section>

<!-- ══ SPLIT PHOTOS ══ -->
<section class="split-section">
  <div class="split-img">
    <img id="img3" alt="Slum Kid">
    <div class="split-overlay">
      <span class="split-label">On crée ce qu'on aime</span>
    </div>
  </div>
  <div class="split-img">
    <img id="img4" alt="Slum Kid">
    <div class="split-overlay">
      <span class="split-label">On crée ce qu'on veut avoir</span>
    </div>
  </div>
</section>

<!-- ══ MOSAIC 3 ══ -->
<section class="mosaic-1">
  <div class="mosaic-text">
    <p class="mosaic-eyebrow">Notre philosophie</p>
    <h2 class="mosaic-title">ON FORCE<br>PERSONNE</h2>
    <p class="mosaic-body">
      On crée ce qu'on aime, ce qu'on veut, ce qu'on aimerait avoir. On fait pas des sappes pour les gens, on fait des sappes pour nous avant tout — en espérant que les gens comme nous nous rejoignent.
      <br><br>
      Si t'es comme nous, tant mieux. Si c'est pas le cas, continue ton chemin. Des marques y'en a plein. On force personne.
    </p>
  </div>
  <div class="mosaic-img">
    <img id="img5" alt="Slum Kid">
  </div>
</section>

<!-- ══ MANIFESTO ══ -->
<section class="manifesto">
  <span class="manifesto-pre">Le Manifeste Slum Kid</span>
  <div class="manifesto-lines">
    <div class="manifesto-line" style="animation-delay:.05s">La même dalle</div>
    <div class="manifesto-line" style="animation-delay:.10s">La même faim</div>
    <div class="manifesto-line" style="animation-delay:.15s">La même détermination</div>
    <div class="manifesto-line" style="animation-delay:.20s">Les mêmes rêves</div>
    <div class="manifesto-line" style="animation-delay:.25s">Les mêmes ambitions</div>
    <div class="manifesto-line" style="animation-delay:.30s">From Slum to Fashion</div>
  </div>
</section>

<!-- ══ CTA ══ -->
<section class="cta-section">
  <div class="cta-bg" id="ctaBg"></div>
  <div class="cta-content">
    <span class="cta-eyebrow">T'es au bon endroit</span>
    <h2 class="cta-title">T'ES UN<br>SLUM KID ?</h2>
    <p class="cta-sub">
      Voilà avec ces quelques petites phrases je pense que tu commences à capter ce que c'est un slum kid. Si t'es un slum kid, t'es au bon endroit.
    </p>
    <a href="/#catalogue" class="btn-white">Voir la collection</a>
  </div>
</section>

<div class="page-footer">
  <span class="foot-logo">Slum Kid</span>
  <span class="foot-copy">© 2026 Slum Kid. Tous droits réservés. By BÖRJA SWISS SOLUTIONS</span>
</div>

<script>
// Load images
var IMGS = {
  hero: "",
  img1: "",
  img2: "",
  img3: "",
  img4: "",
  img5: ""
};

function loadImgs() {
  document.getElementById('heroBg').style.backgroundImage = 'url(' + IMGS.hero + ')';
  document.getElementById('img1').src = IMGS.img1;
  document.getElementById('img2').src = IMGS.img2;
  document.getElementById('img3').src = IMGS.img3;
  document.getElementById('img4').src = IMGS.img4;
  document.getElementById('img5').src = IMGS.img5;
  document.getElementById('ctaBg').style.backgroundImage = 'url(' + IMGS.img3 + ')';
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', loadImgs);
else loadImgs();

// Nav scroll
window.addEventListener('scroll', function() {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 60);
});
</script>
