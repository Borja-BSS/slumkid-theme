<div class="toast" id="toast">Ajouté au panier</div>

<script>
var IMGS = {
  p1: "",
  p2: "",
  p3: "",
  p4: "",
  p5: ""
};

var prices = {
  jacket: ['85.00 CHF', 'Grey Tear-Off Jacket'],
  jogger: ['75.00 CHF', 'Grey Tear-Off Jogger'],
  set:    ['150.00 CHF', 'Set Complet (Jacket + Jogger)']
};
function switchItem(btn, key) {
  document.querySelectorAll('.size-btn').forEach(function(b){ if(['jacket','jogger','set'].indexOf(b.getAttribute('onclick')||'') === -1) return; });
  btn.parentElement.querySelectorAll('button').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('priceMain').textContent = prices[key][0];
  document.getElementById('priceLabel').textContent = prices[key][1];
}
function loadImgs() {
  document.getElementById('t1').src = IMGS.p1;
  document.getElementById('t2').src = IMGS.p2;
  document.getElementById('t3').src = IMGS.p3;
  document.getElementById('t4').src = IMGS.p4;
  var t5 = document.getElementById('t5'); if(t5) t5.src = IMGS.p1;
  document.getElementById('mainImg').src = IMGS.p1;
  document.getElementById('d1').src = IMGS.p3;
  document.getElementById('banner1').src = IMGS.p2;
  document.getElementById('d2').src = IMGS.p4;
  document.getElementById('banner2').src = IMGS.p1;
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', loadImgs);
else loadImgs();

// Gallery clicks
document.querySelectorAll('.thumb').forEach(function(th) {
  th.addEventListener('click', function() {
    document.querySelectorAll('.thumb').forEach(function(t){ t.classList.remove('active'); });
    th.classList.add('active');
    document.getElementById('mainImg').src = IMGS[th.dataset.src];
  });
});

// Size picker
function pick(btn) {
  document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('sizeVal').textContent = btn.textContent;
}

// Accordions
function toggleAcc(id) {
  var body = document.getElementById(id);
  var trigger = body.previousElementSibling;
  var isOpen = body.classList.contains('open');
  body.classList.toggle('open');
  trigger.classList.toggle('open');
}

// Cart
function cartGo(productUrl) {
  var t = document.getElementById('toast');
  t.classList.add('show');
  var size = document.getElementById('sizeVal') ? document.getElementById('sizeVal').textContent : '';
  t.textContent = size ? 'Taille ' + size + ' — Ajouté au panier' : 'Ajouté au panier';
  setTimeout(function(){
    t.classList.remove('show');
    window.location.href = productUrl || '/cart';
  }, 1400);
}
</script>

<div class="sq-overlay" id="sqOverlay" onclick="sqCloseOutside(event)">
  <div class="sq-card">
    <div class="sq-header">
      <div><div class="sq-title">Find My Size</div><div class="sq-sub">3 questions — résultat immédiat</div></div>
      <button class="sq-close" onclick="sqClose()">✕</button>
    </div>
    <div class="sq-progress">
      <div class="sq-step active" id="sqp1"></div>
      <div class="sq-step" id="sqp2"></div>
      <div class="sq-step" id="sqp3"></div>
    </div>
    <div id="sqStep1">
      <p class="sq-q">Quelle est ta taille ?</p>
      <div class="sq-options">
        <button class="sq-opt" onclick="sqAnswer(1,0)">Moins de 160 cm</button>
        <button class="sq-opt" onclick="sqAnswer(1,0.5)">160 – 165 cm</button>
        <button class="sq-opt" onclick="sqAnswer(1,1)">166 – 172 cm</button>
        <button class="sq-opt" onclick="sqAnswer(1,2)">173 – 179 cm</button>
        <button class="sq-opt" onclick="sqAnswer(1,3)">180 – 186 cm</button>
        <button class="sq-opt" onclick="sqAnswer(1,4)">Plus de 186 cm</button>
      </div>
    </div>
    <div id="sqStep2" style="display:none">
      <p class="sq-q">Quel est ton poids ?</p>
      <div class="sq-options">
        <button class="sq-opt" onclick="sqAnswer(2,0)">Moins de 50 kg</button>
        <button class="sq-opt" onclick="sqAnswer(2,0.5)">50 – 60 kg</button>
        <button class="sq-opt" onclick="sqAnswer(2,1)">61 – 72 kg</button>
        <button class="sq-opt" onclick="sqAnswer(2,2)">73 – 84 kg</button>
        <button class="sq-opt" onclick="sqAnswer(2,3)">85 – 99 kg</button>
        <button class="sq-opt" onclick="sqAnswer(2,4)">Plus de 100 kg</button>
      </div>
    </div>
    <div id="sqStep3" style="display:none">
      <p class="sq-q">Comment tu préfères porter tes vêtements ?</p>
      <div class="sq-options">
        <button class="sq-opt" onclick="sqAnswer(3,-0.5)">Fitted — proche du corps</button>
        <button class="sq-opt" onclick="sqAnswer(3,0)">Regular — ni trop large ni trop serré</button>
        <button class="sq-opt" onclick="sqAnswer(3,0.5)">Oversized — comme porté sur la marque</button>
      </div>
    </div>
    <div id="sqResult" style="display:none">
      <div class="sq-result">
        <span class="sq-result-label">Ta taille recommandée</span>
        <span class="sq-result-size" id="sqFinalSize">M</span>
        <p class="sq-result-desc" id="sqDesc"></p>
        <div id="sqTableWrap"></div>
        <div class="sq-btns">
          <button class="sq-btn-apply" onclick="sqApply()">Sélectionner cette taille</button>
          <button class="sq-btn-reset" onclick="sqReset()">Recommencer</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var SIZES = ['XS','S','M','L','XL'];
  var ans = []; var finalSize = 'M';
  var SD = {
  cols: ['Taille','A — Largeur','B — Longueur','C — Manche'],
  rows: [['XS','52 cm','66 cm','60 cm'],['S','54 cm','67 cm','61 cm'],['M','56 cm','68 cm','62 cm'],['L','58 cm','69 cm','63 cm'],['XL','60 cm','70 cm','64 cm']]
};
  window.sqOpen = function() { sqReset(); document.getElementById('sqOverlay').classList.add('open'); document.body.style.overflow='hidden'; };
  window.sqClose = function() { document.getElementById('sqOverlay').classList.remove('open'); document.body.style.overflow=''; };
  window.sqCloseOutside = function(e) { if(e.target===document.getElementById('sqOverlay')) window.sqClose(); };
  window.sqAnswer = function(step, val) {
    ans[step-1]=val;
    event.currentTarget.parentElement.querySelectorAll('.sq-opt').forEach(function(o){o.classList.remove('selected');});
    event.currentTarget.classList.add('selected');
    setTimeout(function() {
      if(step<3) {
        document.getElementById('sqStep'+step).style.display='none';
        document.getElementById('sqStep'+(step+1)).style.display='block';
        upProg(step+1);
      } else { compute(); }
    }, 280);
  };
  function upProg(a) {
    ['sqp1','sqp2','sqp3'].forEach(function(id,i) {
      document.getElementById(id).className='sq-step'+(i+1<a?' done':i+1===a?' active':'');
    });
  }
  function compute() {
    var score=(ans[0]||0)+(ans[1]||0)+(ans[2]||0);
    var idx=Math.round(Math.min(Math.max(score/2,0),4));
    finalSize=SIZES[idx];
    document.getElementById('sqFinalSize').textContent=finalSize;
    var fl=ans[2]<0?'un fit fitted':ans[2]>0?'un fit oversized':'un fit regular';
    document.getElementById('sqDesc').textContent='La taille '+finalSize+' est idéale pour '+fl+'.';
    var h='<table class="sq-table"><thead><tr>';
    SD.cols.forEach(function(c){h+='<th>'+c+'</th>';});
    h+='</tr></thead><tbody>';
    SD.rows.forEach(function(row){
      var hl=row[0]===finalSize?' class="hl"':'';
      h+='<tr'+hl+'>';row.forEach(function(c){h+='<td>'+c+'</td>';});h+='</tr>';
    });
    h+='</tbody></table>';
    document.getElementById('sqTableWrap').innerHTML=h;
    ['sqStep1','sqStep2','sqStep3'].forEach(function(id){document.getElementById(id).style.display='none';});
    document.getElementById('sqResult').style.display='block';
    upProg(4);
  }
  window.sqApply=function(){
    document.querySelectorAll('.size-btn').forEach(function(b){b.classList.remove('active');if(b.textContent.trim()===finalSize&&!b.classList.contains('sold'))b.classList.add('active');});
    var sv=document.getElementById('sizeVal');if(sv)sv.textContent=finalSize;
    window.sqClose();
  };
  window.sqReset=function(){
    ans=[];
    ['sqStep1','sqStep2','sqStep3'].forEach(function(id,i){document.getElementById(id).style.display=i===0?'block':'none';document.querySelectorAll('#'+id+' .sq-opt').forEach(function(o){o.classList.remove('selected');});});
    document.getElementById('sqResult').style.display='none';upProg(1);
  };
})();
</script>
