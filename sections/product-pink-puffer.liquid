<style>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --white: #ffffff; --black: #0a0a0a; --gray: #86868b;
  --light: #f5f5f7; --mid: #e0e0e0;
  --glass-bg: rgba(255,255,255,0.72);
  --glass-border: rgba(255,255,255,0.55);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.10), 0 1.5px 0 rgba(255,255,255,0.7) inset;
  --radius-btn: 980px;
  --ease: cubic-bezier(0.4,0,0.2,1);
  --font: -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: var(--font); background: var(--white); color: var(--black); overflow-x: hidden; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; width: 100%; z-index: 200; height: 52px;
  background: rgba(255,255,255,0.82);
  backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: space-between; padding: 0 2.4rem;
}
.nav-logo { font-size: 0.95rem; font-weight: 800; letter-spacing: 0.18em; color: var(--black); text-decoration: none; text-transform: uppercase; }
.nav-back { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; color: rgba(0,0,0,0.45); text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
.nav-back:hover { color: var(--black); }
.nav-icon-btn { background: none; border: none; cursor: pointer; color: rgba(0,0,0,0.65); padding: 0.3rem; display: flex; }

/* HERO SPLIT */
.hero { display: grid; grid-template-columns: 1fr 1fr; height: 100vh; padding-top: 52px; }

/* Gallery */
.gallery { position: sticky; top: 52px; height: calc(100vh - 52px); display: grid; grid-template-columns: 72px 1fr; gap: 6px; background: var(--light); }
.thumbs-col { display: flex; flex-direction: column; gap: 6px; padding: 6px 0 6px 6px; overflow-y: auto; scrollbar-width: none; }
.thumbs-col::-webkit-scrollbar { display: none; }
.thumb { flex-shrink: 0; width: 66px; height: 82px; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; border-radius: 2px; }
.thumb.active { border-color: var(--black); }
.thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.main-view { position: relative; overflow: hidden; }
.main-view img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.35s var(--ease); cursor: zoom-in; }
.hero-badge {
  position: absolute; top: 1.2rem; right: 1.2rem;
  background: rgba(10,10,10,0.75); backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.15); color: var(--white);
  font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
  padding: 0.45rem 0.9rem; border-radius: var(--radius-btn);
}

/* Product Panel */
.product-panel { display: flex; flex-direction: column; justify-content: center; padding: 3.5rem 3rem; overflow-y: auto; background: var(--white); }
.product-season { font-size: 0.6rem; letter-spacing: 0.22em; font-weight: 600; color: var(--gray); text-transform: uppercase; margin-bottom: 0.7rem; }
.product-name { font-size: clamp(2.6rem, 4.5vw, 4.2rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.9; text-transform: uppercase; margin-bottom: 0.5rem; }
.product-tagline { font-size: 0.72rem; color: var(--gray); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 2rem; font-weight: 500; }

/* Size selector */
.size-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; }
.size-label { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray); }
.size-guide { font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray); text-decoration: underline; cursor: pointer; }
.size-grid { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.8rem; }
.size-btn { min-width: 46px; height: 46px; padding: 0 0.5rem; border: 1px solid var(--mid); background: transparent; font-family: var(--font); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; border-radius: var(--radius-btn); color: var(--black); transition: all 0.2s; }
.size-btn:hover { border-color: var(--black); }
.size-btn.active { background: var(--black); color: var(--white); border-color: var(--black); }
.size-btn.sold { color: var(--mid); cursor: not-allowed; text-decoration: line-through; }

/* Price */
.price-block { margin-bottom: 1.6rem; }
.price-main { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.03em; display: block; }
.price-label { font-size: 0.62rem; color: var(--gray); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.2rem; }

/* Buttons */
.buy-stack { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.6rem; }
.btn-primary { width: 100%; padding: 0.9rem; background: var(--black); color: var(--white); border: none; border-radius: var(--radius-btn); font-family: var(--font); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
.btn-primary:hover { opacity: 0.84; transform: scale(0.99); }
.btn-glass { width: 100%; padding: 0.9rem; background: var(--glass-bg); backdrop-filter: blur(20px) saturate(160%); border: 1px solid rgba(0,0,0,0.12); box-shadow: var(--glass-shadow); color: var(--black); border-radius: var(--radius-btn); font-family: var(--font); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: background 0.2s, transform 0.15s; }
.btn-glass:hover { background: rgba(255,255,255,0.9); transform: scale(0.99); }

/* Delivery */
.delivery { display: flex; align-items: center; gap: 0.7rem; font-size: 0.7rem; color: var(--gray); letter-spacing: 0.02em; padding-top: 1.2rem; border-top: 1px solid var(--mid); }
.dot-green { width: 7px; height: 7px; border-radius: 50%; background: #34c759; flex-shrink: 0; }

/* Accordions */
.accordion { margin-top: 1.8rem; border-top: 1px solid var(--mid); }
.acc-item { border-bottom: 1px solid var(--mid); }
.acc-trigger { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 1rem 0; background: none; border: none; cursor: pointer; font-family: var(--font); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--black); }
.acc-trigger .icon { font-size: 1.1rem; transition: transform 0.3s; line-height: 1; }
.acc-trigger.open .icon { transform: rotate(45deg); }
.acc-body { max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease); }
.acc-body.open { max-height: 600px; }
.acc-content { padding: 0 0 1.2rem; font-size: 0.78rem; color: rgba(0,0,0,0.65); line-height: 1.7; }
.acc-content ul { padding-left: 1rem; }
.acc-content li { margin-bottom: 0.3rem; }

/* Detail sections */
.detail-row { display: grid; grid-template-columns: 1fr 1fr; min-height: 85vh; border-top: 1px solid rgba(0,0,0,0.06); }
.detail-row.reverse { direction: rtl; }
.detail-row.reverse > * { direction: ltr; }
.detail-img { position: sticky; top: 52px; height: calc(100vh - 52px); overflow: hidden; }
.detail-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.detail-body { display: flex; flex-direction: column; justify-content: center; padding: 5rem 4rem; }
.detail-eyebrow { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gray); margin-bottom: 0.8rem; }
.detail-title { font-size: clamp(2rem, 3.5vw, 3.2rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.92; text-transform: uppercase; margin-bottom: 2.8rem; }
.feat-list { list-style: none; counter-reset: feat; }
.feat-list li { counter-increment: feat; display: flex; align-items: flex-start; gap: 1.4rem; padding: 1rem 0; border-bottom: 1px solid rgba(0,0,0,0.07); font-size: 0.8rem; letter-spacing: 0.01em; color: rgba(0,0,0,0.7); line-height: 1.55; opacity: 0; transform: translateY(12px); animation: fadeUp 0.5s var(--ease) forwards; }
.feat-list li:last-child { border-bottom: none; }
.feat-list li::before { content: counter(feat, decimal-leading-zero); font-size: 0.56rem; font-weight: 800; letter-spacing: 0.1em; color: rgba(0,0,0,0.18); padding-top: 0.2rem; flex-shrink: 0; min-width: 22px; }
@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

/* Full banner */
.full-banner { height: 70vh; position: relative; overflow: hidden; }
.full-banner img { width: 100%; height: 100%; object-fit: cover; display: block; object-position: center 30%; }
.banner-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 60%, transparent 100%); display: flex; align-items: flex-end; padding: 4rem 5rem; }
.banner-glass-card { background: var(--glass-bg); backdrop-filter: blur(28px) saturate(160%); border: 1px solid var(--glass-border); box-shadow: var(--glass-shadow); border-radius: 18px; padding: 2rem 2.4rem; max-width: 400px; }
.banner-card-eyebrow { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(0,0,0,0.45); margin-bottom: 0.5rem; }
.banner-card-title { font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.95; text-transform: uppercase; color: var(--black); margin-bottom: 1.2rem; }
.btn-dark { display: inline-flex; align-items: center; background: var(--black); color: var(--white); border: none; border-radius: var(--radius-btn); padding: 0.72rem 1.6rem; font-family: var(--font); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; transition: opacity 0.2s; text-decoration: none; }
.btn-dark:hover { opacity: 0.82; }

/* Size guide table */
.size-table { width: 100%; border-collapse: collapse; margin-top: 0.8rem; font-size: 0.75rem; }
.size-table th { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray); padding: 0.5rem 0.4rem; border-bottom: 1px solid rgba(0,0,0,0.1); text-align: center; }
.size-table td { padding: 0.55rem 0.4rem; text-align: center; color: var(--black); border-bottom: 1px solid rgba(0,0,0,0.06); font-weight: 500; }
.size-table tr:last-child td { border-bottom: none; }

/* Toast */
.toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(80px); background: rgba(10,10,10,0.88); color: var(--white); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.1); padding: 0.85rem 2rem; border-radius: var(--radius-btn); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; z-index: 999; transition: transform 0.4s var(--ease); white-space: nowrap; }
.toast.show { transform: translateX(-50%) translateY(0); }

/* Footer */
.page-footer { background: #0a0a0a; color: var(--white); padding: 2rem 2.5rem; display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 10; }
.foot-logo { font-size: 0.85rem; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; }
.foot-copy { font-size: 0.68rem; color: rgba(255,255,255,0.3); letter-spacing: 0.06em; }

@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; height: auto; }
  .gallery { position: relative; top: 0; height: 80vw; grid-template-columns: 60px 1fr; }
  .product-panel { padding: 2rem 1.5rem; }
  .detail-row { grid-template-columns: 1fr; }
  .detail-row.reverse { direction: ltr; }
  .detail-img { position: relative; height: 60vw; top: 0; }
  .detail-body { padding: 3rem 1.5rem; }
  .full-banner { height: 60vw; }
  .banner-overlay { padding: 2rem; }
  nav { padding: 0 1.2rem; }
}

/* ════ SIZE QUIZ ════ */
.sq-overlay { position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.4);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.35s; }
.sq-overlay.open { opacity:1;pointer-events:all; }
.sq-card { background:rgba(255,255,255,0.82);backdrop-filter:blur(32px) saturate(180%);border:1px solid rgba(255,255,255,0.55);box-shadow:0 8px 40px rgba(0,0,0,0.12);border-radius:22px;padding:2.2rem 2rem;width:min(520px,92vw);transform:translateY(20px) scale(0.97);transition:transform 0.4s; }
.sq-overlay.open .sq-card { transform:translateY(0) scale(1); }
.sq-header { display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.6rem; }
.sq-title { font-size:1rem;font-weight:800;letter-spacing:-0.02em;text-transform:uppercase; }
.sq-sub { font-size:0.65rem;color:var(--gray);margin-top:0.2rem; }
.sq-close { background:rgba(0,0,0,0.07);border:none;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:0.9rem;display:flex;align-items:center;justify-content:center; }
.sq-close:hover { background:rgba(0,0,0,0.14); }
.sq-progress { display:flex;gap:4px;margin-bottom:1.8rem; }
.sq-step { flex:1;height:3px;border-radius:2px;background:rgba(0,0,0,0.1);transition:background 0.35s; }
.sq-step.done { background:var(--black); } .sq-step.active { background:rgba(0,0,0,0.4); }
.sq-q { font-size:0.85rem;font-weight:700;color:var(--black);margin-bottom:1.1rem; }
.sq-options { display:flex;flex-direction:column;gap:7px; }
.sq-opt { padding:0.78rem 1.1rem;background:rgba(255,255,255,0.7);border:1px solid rgba(0,0,0,0.1);border-radius:var(--radius-btn);font-family:var(--font);font-size:0.78rem;font-weight:500;color:var(--black);cursor:pointer;text-align:left;transition:all 0.2s; }
.sq-opt:hover { background:rgba(0,0,0,0.07);border-color:rgba(0,0,0,0.25); }
.sq-opt.selected { background:var(--black);color:var(--white);border-color:var(--black); }
.sq-result { text-align:center; }
.sq-result-label { font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--gray);display:block;margin-bottom:0.4rem; }
.sq-result-size { font-size:4.5rem;font-weight:900;letter-spacing:-0.06em;color:var(--black);display:block;line-height:1;margin-bottom:0.4rem; }
.sq-result-desc { font-size:0.75rem;color:var(--gray);line-height:1.5;margin-bottom:1.2rem; }
.sq-table { width:100%;border-collapse:collapse;margin-bottom:1.2rem;font-size:0.72rem; }
.sq-table th { font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray);padding:0.5rem;border-bottom:1px solid rgba(0,0,0,0.1);text-align:center; }
.sq-table td { padding:0.5rem;text-align:center;border-bottom:1px solid rgba(0,0,0,0.06);font-weight:500; }
.sq-table tr.hl td { background:rgba(0,0,0,0.05);font-weight:800; }
.sq-table tr:last-child td { border-bottom:none; }
.sq-btns { display:flex;flex-direction:column;gap:7px; }
.sq-btn-apply { width:100%;padding:0.88rem;background:var(--black);color:var(--white);border:none;border-radius:var(--radius-btn);font-family:var(--font);font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:opacity 0.2s; }
.sq-btn-apply:hover { opacity:0.82; }
.sq-btn-reset { width:100%;padding:0.82rem;background:rgba(0,0,0,0.06);color:var(--black);border:none;border-radius:var(--radius-btn);font-family:var(--font);font-size:0.78rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer; }
.sq-btn-reset:hover { background:rgba(0,0,0,0.12); }
</style>

