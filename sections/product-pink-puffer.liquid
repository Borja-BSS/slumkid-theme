<script>
var IMGS = {
  p1: "",
  p2: "",
  p3: "",
  p4: "",
  p5: ""
};

function loadImgs() {
  document.getElementById('t1').src = IMGS.p1;
  document.getElementById('t2').src = IMGS.p2;
  document.getElementById('t3').src = IMGS.p3;
  document.getElementById('t4').src = IMGS.p4;
  document.getElementById('t5').src = IMGS.p5;
  document.getElementById('mainImg').src = IMGS.p1;
  document.getElementById('d1').src = IMGS.p5;
  document.getElementById('banner1').src = IMGS.p2;
  document.getElementById('d2').src = IMGS.p4;
  document.getElementById('banner2').src = IMGS.p3;
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', loadImgs);
else loadImgs();

// Gallery clicks
document.querySelectorAll('.thumb').forEach(function(th) {
  th.addEventListener('click', function() {
    document.querySelectorAll('.thumb').forEach(function(t){ t.classList.remove('active'); });
    th.classList.add('active');
    document.getElementById('mainImg').src = IMGS[th.dataset.src];
  });
});

// Size picker
function pick(btn) {
  document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('sizeVal').textContent = btn.textContent;
}

// Accordions
function toggleAcc(id) {
  var body = document.getElementById(id);
  var trigger = body.previousElementSibling;
  var isOpen = body.classList.contains('open');
  body.classList.toggle('open');
  trigger.classList.toggle('open');
}

// Cart
function cartGo() {
  var t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(function(){
    t.classList.remove('show');
    window.location.href = 'https://slumkid.myshopify.com/checkout';
  }, 1200);
}
</script>

<script>
var IMGS = {
  p1: "{{ 'pp1.jpg' | asset_url }}",
  p2: "{{ 'pp2.jpg' | asset_url }}",
  p3: "{{ 'pp3.jpg' | asset_url }}",
  p4: "{{ 'pp4.jpg' | asset_url }}",
  p5: "{{ 'pp5.jpg' | asset_url }}"
};

function loadImgs() {
  document.getElementById('t1').src = IMGS.p1;
  document.getElementById('t2').src = IMGS.p2;
  document.getElementById('t3').src = IMGS.p3;
  document.getElementById('t4').src = IMGS.p4;
  document.getElementById('t5').src = IMGS.p5;
  document.getElementById('mainImg').src = IMGS.p1;
  document.getElementById('d1').src = IMGS.p5;
  document.getElementById('banner1').src = IMGS.p2;
  document.getElementById('d2').src = IMGS.p4;
  document.getElementById('banner2').src = IMGS.p3;
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', loadImgs);
else loadImgs();

document.querySelectorAll('.thumb').forEach(function(th) {
  th.addEventListener('click', function() {
    document.querySelectorAll('.thumb').forEach(function(t){ t.classList.remove('active'); });
    th.classList.add('active');
    document.getElementById('mainImg').src = IMGS[th.dataset.src];
  });
});
function pick(btn) {
  document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('sizeVal').textContent = btn.textContent;
}
function toggleAcc(id) {
  var body = document.getElementById(id);
  var trigger = body.previousElementSibling;
  body.classList.toggle('open');
  trigger.classList.toggle('open');
}
function cartGo() {
  var t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); window.location.href='https://slumkid.myshopify.com/checkout'; }, 1200);
}
</script>

