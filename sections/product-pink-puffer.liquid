}

/* Cart fallback */
function cartGo() {
  if (window.SKShopify) { window.SKShopify.addToCart(); return; }
  var t = document.getElementById('toast');
  if (t) { t.textContent = 'Ajout...'; t.classList.add('show'); }
  setTimeout(function() { if (t) t.classList.remove('show'); window.location.href = '/cart'; }, 1000);
}
</script>

<script>
/* Size Quiz */
(function() {
  var SIZES = ['XS','S','M','L','XL'];
  var ans = []; var finalSize = 'M';
  var SD = {
    cols: ['Taille','Longueur','Poitrine','Manche raglan'],
    rows: [['XS','109 cm','56 cm','77 cm'],['S','114 cm','58.5 cm','79 cm'],['M','119 cm','61 cm','81 cm'],['L','124 cm','63.5 cm','83 cm'],['XL','129 cm','66 cm','85 cm']]
  };
  window.sqOpen = function() { sqReset(); document.getElementById('sqOverlay').classList.add('open'); document.body.style.overflow='hidden'; };
  window.sqClose = function() { document.getElementById('sqOverlay').classList.remove('open'); document.body.style.overflow=''; };
  window.sqCloseOutside = function(e) { if(e.target===document.getElementById('sqOverlay')) window.sqClose(); };
  window.sqAnswer = function(step, val) {
    ans[step-1]=val;
    event.currentTarget.parentElement.querySelectorAll('.sq-opt').forEach(function(o){o.classList.remove('selected');});
    event.currentTarget.classList.add('selected');
    setTimeout(function() {
      if(step<3) { document.getElementById('sqStep'+step).style.display='none'; document.getElementById('sqStep'+(step+1)).style.display='block'; upProg(step+1); }
      else { compute(); }
    }, 280);
  };
  function upProg(a) { ['sqp1','sqp2','sqp3'].forEach(function(id,i) { document.getElementById(id).className='sq-step'+(i+1<a?' done':i+1===a?' active':''); }); }
  function compute() {
    var score=(ans[0]||0)+(ans[1]||0)+(ans[2]||0);
    var idx=Math.round(Math.min(Math.max(score/2,0),4));
    finalSize=SIZES[idx];
    document.getElementById('sqFinalSize').textContent=finalSize;
    var fl=ans[2]<0?'un fit fitted':ans[2]>0?'un fit oversized':'un fit regular';
    document.getElementById('sqDesc').textContent='La taille '+finalSize+' est idéale pour '+fl+'.';
    var h='<table class="sq-table"><thead><tr>'; SD.cols.forEach(function(c){h+='<th>'+c+'</th>';}); h+='</tr></thead><tbody>';
    SD.rows.forEach(function(row){var hl=row[0]===finalSize?' class="hl"':'';h+='<tr'+hl+'>';row.forEach(function(c){h+='<td>'+c+'</td>';});h+='</tr>';});
    h+='</tbody></table>'; document.getElementById('sqTableWrap').innerHTML=h;
    ['sqStep1','sqStep2','sqStep3'].forEach(function(id){document.getElementById(id).style.display='none';});
    document.getElementById('sqResult').style.display='block'; upProg(4);
  }
  window.sqApply=function(){ document.querySelectorAll('.size-btn').forEach(function(b){b.classList.remove('active');if(b.textContent.trim()===finalSize&&!b.classList.contains('sold'))b.classList.add('active');}); var sv=document.getElementById('sizeVal');if(sv)sv.textContent=finalSize; window.sqClose(); };
  window.sqReset=function(){ ans=[]; ['sqStep1','sqStep2','sqStep3'].forEach(function(id,i){document.getElementById(id).style.display=i===0?'block':'none';document.querySelectorAll('#'+id+' .sq-opt').forEach(function(o){o.classList.remove('selected');});}); document.getElementById('sqResult').style.display='none';upProg(1); };
})();
</script>

<script type="text/javascript">
/* Shopify Buy SDK */
(function() {
  var DOMAIN = 'b1i9bd-14.myshopify.com';
  var TOKEN  = 'dee105ca8f9997a702cfbc013fd5e30f';
  var PID    = '9856965509448';
  var SDK    = 'https://sdks.shopifycdn.com/buy-button/latest/buy-button-storefront.min.js';

  function initShopify() {
    var client = ShopifyBuy.buildClient({ domain: DOMAIN, storefrontAccessToken: TOKEN });
    window.SKShopify = {
      getCheckout: function(cb) {
        var id = localStorage.getItem('sk_checkout_id');
        var create = function() {
          client.checkout.create().then(function(c) { localStorage.setItem('sk_checkout_id', c.id); cb(c); });
        };
        if (id) { client.checkout.fetch(id).then(function(c) { if (c && !c.completedAt) cb(c); else create(); }).catch(create); }
        else { create(); }
      },
      getVariants: function(cb) {
        client.product.fetch('gid://shopify/Product/' + PID).then(function(p) { if (p && p.variants) cb(p.variants); });
      },
      addToCart: function() {
        var size = (document.getElementById('sizeVal') || {}).textContent || 'XS';
        var toast = document.getElementById('toast');
        if (toast) { toast.textContent = 'Chargement...'; toast.classList.add('show'); }
        window.SKShopify.getVariants(function(variants) {
          var v = variants.find(function(x) { return x.title === size || x.title.indexOf(size) !== -1; }) || variants[0];
          window.SKShopify.getCheckout(function(checkout) {
            client.checkout.addLineItems(checkout.id, [{variantId: v.id, quantity: 1}]).then(function(c) {
              if (toast) { toast.textContent = 'Taille ' + size + ' — Ajouté !'; }
              setTimeout(function() { if (toast) toast.classList.remove('show'); window.location.href = c.webUrl; }, 900);
            });
          });
        });
      },
      buyNow: function() {
        var size = (document.getElementById('sizeVal') || {}).textContent || 'XS';
        window.SKShopify.getVariants(function(variants) {
          var v = variants.find(function(x) { return x.title === size || x.title.indexOf(size) !== -1; }) || variants[0];
          window.SKShopify.getCheckout(function(checkout) {
            client.checkout.addLineItems(checkout.id, [{variantId: v.id, quantity: 1}]).then(function(c) { window.location.href = c.webUrl; });
          });
        });
      }
    };
  }

  if (window.ShopifyBuy && window.ShopifyBuy.UI) { initShopify(); }
  else { var s = document.createElement('script'); s.async = true; s.src = SDK; s.onload = initShopify; document.head.appendChild(s); }
})();
</script>

