      'S':  { id: '52767401541960', price: 129.90, name: 'Storm Jacket', stock: 4 },
      'M':  { id: '52767401574728', price: 129.90, name: 'Storm Jacket', stock: 6 },
      'L':  { id: '52767401607496', price: 129.90, name: 'Storm Jacket', stock: 0 },
      'XL': { id: '52767401640264', price: 129.90, name: 'Storm Jacket', stock: 0 }
    },
    jogger: {
      'XS': { id: '52767437750600', price: 84.90, name: 'Storm Jogger', stock: 2 },
      'S':  { id: '52767437783368', price: 84.90, name: 'Storm Jogger', stock: 4 },
      'M':  { id: '52767437816136', price: 84.90, name: 'Storm Jogger', stock: 6 },
      'L':  { id: '52767437848904', price: 84.90, name: 'Storm Jogger', stock: 1 },
      'XL': { id: '52767437881672', price: 84.90, name: 'Storm Jogger', stock: 1 }
    }
  };

  /* ── Helpers ── */
  function getActiveTab() {
    var el = document.querySelector('.type-tab.active');
    return el && el.textContent.trim().toLowerCase() === 'jogger' ? 'jogger' : 'jacket';
  }
  function getSize() {
    return ((document.getElementById('sizeVal') || {}).textContent || 'M').trim();
  }
  function getCart() {
    try { return JSON.parse(localStorage.getItem('sk_cart') || '[]'); } catch(e) { return []; }
  }
  function saveCart(cart) { localStorage.setItem('sk_cart', JSON.stringify(cart)); }

  /* ── SDK Shopify pour générer le lien checkout ── */
  var skClient = null;

  function initSDK(cb) {
    if (skClient) { cb(skClient); return; }
    if (window.ShopifyBuy) {
      skClient = ShopifyBuy.buildClient({ domain: SHOPIFY_DOMAIN, storefrontAccessToken: STOREFRONT_TOKEN });
      cb(skClient);
      return;
    }
    var s = document.createElement('script');
    s.src = SDK_URL; s.async = true;
    s.onload = function() {
      skClient = ShopifyBuy.buildClient({ domain: SHOPIFY_DOMAIN, storefrontAccessToken: STOREFRONT_TOKEN });
      cb(skClient);
    };
    document.head.appendChild(s);
  }

  /* Crée un checkout via SDK et redirige */
  function checkoutWithSDK(tab, size, openCart) {
    var variant = VARIANTS[tab][size];
    if (!variant) { alert('Taille non disponible.'); return; }

    var toast = document.getElementById('toast');
    if (toast) { toast.textContent = 'Chargement...'; toast.classList.add('show'); }

    initSDK(function(client) {
      /* Variant GID format */
      var variantGid = 'gid://shopify/ProductVariant/' + variant.id;

      client.checkout.create().then(function(checkout) {
        return client.checkout.addLineItems(checkout.id, [{ variantId: variantGid, quantity: 1 }]);
      }).then(function(checkout) {
        if (toast) toast.textContent = variant.name + ' — Taille ' + size + ' ajouté !';
        setTimeout(function() {
          if (toast) toast.classList.remove('show');
          if (openCart) {
            /* Ajouter au panier custom + ouvrir le drawer */
            var img = document.getElementById('mainImg') ? document.getElementById('mainImg').src : '';
            var cart = getCart();
            var existing = cart.find(function(i) { return i.variantId === variant.id && i.size === size; });
            if (existing) { existing.qty += 1; } 
            else { cart.push({ variantId: variant.id, checkoutUrl: checkout.webUrl, name: variant.name, size: size, price: variant.price, qty: 1, img: img }); }
            saveCart(cart);
            renderCart();
            window.skCartOpen();
          } else {
            /* Acheter maintenant → checkout direct */
            window.location.href = checkout.webUrl;
          }
        }, 800);
      }).catch(function(err) {
        console.error('Checkout error:', err);
        if (toast) { toast.textContent = 'Erreur — réessaie'; setTimeout(function(){ toast.classList.remove('show'); }, 2000); }
      });
    });
  }

  /* ── Rendu du panier ── */
  function renderCart() {
    var cart = getCart();
    var itemsEl = document.getElementById('skCartItems');
    var emptyEl = document.getElementById('skCartEmpty');
    var footerEl = document.getElementById('skCartFooter');
    var countEl = document.getElementById('skCartCount');
    var badgeEl = document.getElementById('skCartBadge');
    var totalEl = document.getElementById('skCartTotal');
    if (!itemsEl) return;

    var totalItems = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    var totalPrice = cart.reduce(function(s, i) { return s + i.price * i.qty; }, 0);

    if (badgeEl) { badgeEl.textContent = totalItems; badgeEl.classList.toggle('visible', totalItems > 0); }
    if (countEl) countEl.textContent = totalItems > 0 ? '(' + totalItems + ')' : '';
    if (totalEl) totalEl.textContent = totalPrice.toFixed(2) + ' CHF';

    itemsEl.querySelectorAll('.sk-cart-item').forEach(function(el) { el.remove(); });

    if (cart.length === 0) {
      if (emptyEl) emptyEl.style.display = 'flex';
      if (footerEl) footerEl.style.display = 'none';
      return;
    }

    if (emptyEl) emptyEl.style.display = 'none';
    if (footerEl) footerEl.style.display = 'block';

    cart.forEach(function(item, idx) {
      var div = document.createElement('div');
      div.className = 'sk-cart-item';
      div.innerHTML =
        '<img class="sk-cart-item-img" src="' + (item.img || '') + '" alt="' + item.name + '">' +
        '<div class="sk-cart-item-info">' +
          '<div class="sk-cart-item-name">' + item.name + '</div>' +
          '<div class="sk-cart-item-variant">Taille ' + item.size + '</div>' +
          '<div class="sk-cart-item-price">' + item.price.toFixed(2) + ' CHF</div>' +
        '</div>' +
        '<div class="sk-cart-item-actions">' +
          '<div class="sk-cart-qty">' +
            '<button class="sk-cart-qty-btn" onclick="skCartQty(' + idx + ',-1)">−</button>' +
            '<span class="sk-cart-qty-val">' + item.qty + '</span>' +
            '<button class="sk-cart-qty-btn" onclick="skCartQty(' + idx + ',1)">+</button>' +
          '</div>' +
          '<button class="sk-cart-remove" onclick="skCartRemove(' + idx + ')">Supprimer</button>' +
        '</div>';
      itemsEl.appendChild(div);
    });
  }

  /* ── Actions panier ── */
  window.skCartOpen = function() {
    renderCart();
    document.getElementById('skCartOverlay').classList.add('open');
    document.getElementById('skCartDrawer').classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  window.skCartClose = function() {
    document.getElementById('skCartOverlay').classList.remove('open');
    document.getElementById('skCartDrawer').classList.remove('open');
    document.body.style.overflow = '';
  };
  window.skCartQty = function(idx, delta) {
    var cart = getCart();
    cart[idx].qty = Math.max(1, cart[idx].qty + delta);
    saveCart(cart); renderCart();
  };
  window.skCartRemove = function(idx) {
    var cart = getCart();
    cart.splice(idx, 1);
    saveCart(cart); renderCart();
  };
  window.skCartCheckout = function() {
    var cart = getCart();
    if (cart.length === 0) return;
    /* Utilise le checkoutUrl du premier item (créé via SDK) */
    if (cart[0].checkoutUrl) {
      window.location.href = cart[0].checkoutUrl;
    } else {
      /* Fallback : créer un nouveau checkout avec tous les items */
      initSDK(function(client) {
        var lineItems = cart.map(function(i) {
          return { variantId: 'gid://shopify/ProductVariant/' + i.variantId, quantity: i.qty };
        });
        client.checkout.create().then(function(checkout) {
          return client.checkout.addLineItems(checkout.id, lineItems);
        }).then(function(checkout) {
          window.location.href = checkout.webUrl;
        });
      });
    }
  };

  /* ── Interface publique ── */
  window.SKShopify = {
    currentTab: 'jacket',
    addToCart: function() {
      var tab = getActiveTab();
      var size = getSize();
      var variant = VARIANTS[tab] && VARIANTS[tab][size];
      if (!variant || variant.stock === 0) {
        var t = document.getElementById('toast');
        if (t) { t.textContent = 'Taille ' + size + ' — Épuisé'; t.classList.add('show'); setTimeout(function(){ t.classList.remove('show'); }, 2000); }
        return;
      }
      checkoutWithSDK(tab, size, true);
    },
    buyNow: function() {
      var tab = getActiveTab();
      var size = getSize();
      var variant = VARIANTS[tab] && VARIANTS[tab][size];
      if (!variant || variant.stock === 0) { alert('Taille non disponible.'); return; }
      checkoutWithSDK(tab, size, false);
    }
  };

  var _orig = window.switchTab;
  window.switchTab = function(el, key) {
    if (_orig) _orig(el, key);
    window.SKShopify.currentTab = key;
  };

  document.addEventListener('DOMContentLoaded', renderCart);
  renderCart();

})();
</script>

