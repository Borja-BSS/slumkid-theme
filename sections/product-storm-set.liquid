    scrollbar-width: none;
  }
  .thumbs-col::-webkit-scrollbar { display: none; }
  .thumb { flex-shrink: 0; width: 72px; height: 90px; }

  /* ── Panel produit : pleine largeur, rien ne dépasse ── */
  .product-panel {
    width: 100vw !important;
    box-sizing: border-box !important;
    padding: 2rem 1.4rem !important;
    height: auto !important;
    overflow: hidden !important;
    justify-content: flex-start;
  }
  .type-tabs { width: 100% !important; box-sizing: border-box !important; }
  .size-grid { width: 100% !important; box-sizing: border-box !important; }
  .buy-stack { width: 100% !important; box-sizing: border-box !important; }
  .btn-primary, .btn-glass {
    width: 100% !important;
    box-sizing: border-box !important;
    font-size: 0.75rem !important;
    letter-spacing: 0.05em !important;
    padding: 0.85rem 1rem !important;
  }

  /* Anti-zoom iOS : 16px sur inputs seulement */
  input, select, textarea { font-size: 16px !important; }
  /* Sections détail : BLOCK — supprime le grid et le direction:rtl */
  .detail-row { display: block !important; direction: ltr !important; width: 100% !important; overflow: hidden; }
  .detail-row.reverse { display: block !important; direction: ltr !important; }
  .detail-row > * { direction: ltr !important; width: 100% !important; box-sizing: border-box; }
  .detail-img { display: block !important; position: relative !important; top: 0 !important; width: 100% !important; height: auto !important; aspect-ratio: 3 / 4; overflow: hidden !important; }
  .detail-img img { width: 100% !important; height: 100% !important; object-fit: cover; object-position: center top; display: block; }
  .detail-body { padding: 2.5rem 1.5rem; width: 100%; box-sizing: border-box; }
  .full-banner { height: auto !important; aspect-ratio: 3 / 4; width: 100% !important; overflow: hidden; }
  .full-banner img { width: 100% !important; height: 100% !important; object-fit: cover; object-position: center top; }
  .banner-overlay { padding: 1.8rem; }
  .dual-strip { display: block !important; width: 100% !important; overflow: hidden; }
  .dual-strip img { width: 100% !important; aspect-ratio: 3 / 4; object-fit: cover; object-position: center top; height: auto !important; display: block; }
  nav { padding: 0 1.2rem; }
}
