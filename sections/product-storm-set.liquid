<script>
var IMGS = {
  p1: "{{ 'storm-set-img-00.jpg' | asset_url }}",
  p2: "{{ 'storm-set-img-01.jpg' | asset_url }}",
  p3: "{{ 'storm-set-img-02.jpg' | asset_url }}",
  p4: "{{ 'storm-set-img-03.jpg' | asset_url }}",
  p5: "{{ 'storm-set-img-04.jpg' | asset_url }}",
  p6: "{{ 'storm-set-img-05.jpg' | asset_url }}",
  p7: "{{ 'storm-set-img-06.jpg' | asset_url }}",
  p8: "{{ 'storm-set-img-07.jpg' | asset_url }}",
  p9: "{{ 'storm-set-img-08.jpg' | asset_url }}",
  p10: "{{ 'storm-set-img-09.jpg' | asset_url }}",
  p11: "{{ 'storm-set-img-10.jpg' | asset_url }}",
  p12: "{{ 'storm-set-img-11.jpg' | asset_url }}"
};
window.IMGS = IMGS;

// Images jogger : cadrage bas pour voir les pieds
var BOTTOM_IMGS = ['p9','p10','p11','p12'];

document.querySelectorAll('.thumb').forEach(function(th) {
  th.addEventListener('click', function() {
    document.querySelectorAll('.thumb').forEach(function(t) { t.classList.remove('active'); });
    th.classList.add('active');
    var key = th.dataset.src;
    var mainImg = document.getElementById('mainImg');
    mainImg.src = IMGS[key];
    // Cadrage : bas pour les photos jogger, haut pour le reste
    mainImg.style.objectPosition = BOTTOM_IMGS.indexOf(key) !== -1 ? 'center bottom' : 'center top';
  });
});

var PRODUCT_IDS = { jacket: '9983380390216', jogger: '9983421808968' };
var prices = { jacket: ['129.90 CHF','Storm Jacket'], jogger: ['84.90 CHF','Storm Jogger'] };
var currentTab = 'jacket';

/* Stock réel par taille */
var STOCK = {
  jacket: { 'XS': 1, 'S': 4, 'M': 6, 'L': 0, 'XL': 0, 'XXL': 0 },
  jogger: { 'XS': 2, 'S': 4, 'M': 6, 'L': 1, 'XL': 1, 'XXL': 0 }
};

function updateSizeButtons(key) {
  var grid = document.getElementById('sizeGrid');
  if (!grid) return;
  var btns = grid.querySelectorAll('.size-btn');
  btns.forEach(function(btn) {
    var size = btn.textContent.trim();
    var stock = (STOCK[key] && STOCK[key][size] !== undefined) ? STOCK[key][size] : 0;
    btn.classList.remove('active', 'sold');
    if (stock === 0) btn.classList.add('sold');
  });
  /* Sélectionner la première taille disponible */
  var first = Array.from(btns).find(function(b) { return !b.classList.contains('sold'); });
  if (first) {
    first.classList.add('active');
    var sv = document.getElementById('sizeVal');
    if (sv) sv.textContent = first.textContent.trim();
  }
}

function switchTab(el, key) {
  document.querySelectorAll('.type-tab').forEach(function(t) { t.classList.remove('active'); });
  el.classList.add('active');
  document.getElementById('priceMain').textContent = prices[key][0];
  document.getElementById('priceLabel').textContent = prices[key][1];
  currentTab = key;
  if (window.SKShopify) window.SKShopify.currentTab = key;
  updateSizeButtons(key);
}

document.addEventListener('DOMContentLoaded', function() { updateSizeButtons('jacket'); });

function pick(btn) {
  if (btn.classList.contains('sold')) return;
  document.querySelectorAll('.size-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('sizeVal').textContent = btn.textContent;
}

function cartGo() {
  if (window.SKShopify) { window.SKShopify.addToCart(); return; }
  var t = document.getElementById('toast');
  if (t) { t.textContent = 'Ajout...'; t.classList.add('show'); }
  setTimeout(function() { if(t) t.classList.remove('show'); window.location.href = '/cart'; }, 1000);
}
</script>

<script>
(function() {
  var SIZES = ['XS','S','M','L','XL'];
  var ans = []; var finalSize = 'M';
  var SD = { cols: ['Taille','A — Largeur','B — Longueur','C — Manche'], rows: [['XS','52 cm','66 cm','60 cm'],['S','54 cm','67 cm','61 cm'],['M','56 cm','68 cm','62 cm'],['L','58 cm','69 cm','63 cm'],['XL','60 cm','70 cm','64 cm']] };
  window.sqOpen = function() { sqReset(); document.getElementById('sqOverlay').classList.add('open'); document.body.style.overflow='hidden'; };
  window.sqClose = function() { document.getElementById('sqOverlay').classList.remove('open'); document.body.style.overflow=''; };
  window.sqCloseOutside = function(e) { if(e.target===document.getElementById('sqOverlay')) window.sqClose(); };
  window.sqAnswer = function(step, val) {
    ans[step-1]=val;
    event.currentTarget.parentElement.querySelectorAll('.sq-opt').forEach(function(o){o.classList.remove('selected');});
    event.currentTarget.classList.add('selected');
    setTimeout(function() {
      if(step<3) { document.getElementById('sqStep'+step).style.display='none'; document.getElementById('sqStep'+(step+1)).style.display='block'; upProg(step+1); }
      else { compute(); }
    }, 280);
  };
  function upProg(a) { ['sqp1','sqp2','sqp3'].forEach(function(id,i) { document.getElementById(id).className='sq-step'+(i+1<a?' done':i+1===a?' active':''); }); }
  function compute() {
    var score=(ans[0]||0)+(ans[1]||0)+(ans[2]||0);
    var idx=Math.round(Math.min(Math.max(score/2,0),4));
    finalSize=SIZES[idx];
    document.getElementById('sqFinalSize').textContent=finalSize;
    var fl=ans[2]<0?'un fit fitted':ans[2]>0?'un fit oversized':'un fit regular';
    document.getElementById('sqDesc').textContent='La taille '+finalSize+' est idéale pour '+fl+'.';
    var h='<table class="sq-table"><thead><tr>'; SD.cols.forEach(function(c){h+='<th>'+c+'</th>';}); h+='</tr></thead><tbody>';
    SD.rows.forEach(function(row){var hl=row[0]===finalSize?' class="hl"':'';h+='<tr'+hl+'>';row.forEach(function(c){h+='<td>'+c+'</td>';});h+='</tr>';});
    h+='</tbody></table>'; document.getElementById('sqTableWrap').innerHTML=h;
    ['sqStep1','sqStep2','sqStep3'].forEach(function(id){document.getElementById(id).style.display='none';});
    document.getElementById('sqResult').style.display='block'; upProg(4);
  }
  window.sqApply=function(){ document.querySelectorAll('.size-btn').forEach(function(b){b.classList.remove('active');if(b.textContent.trim()===finalSize&&!b.classList.contains('sold'))b.classList.add('active');}); var sv=document.getElementById('sizeVal');if(sv)sv.textContent=finalSize; window.sqClose(); };
  window.sqReset=function(){ ans=[]; ['sqStep1','sqStep2','sqStep3'].forEach(function(id,i){document.getElementById(id).style.display=i===0?'block':'none';document.querySelectorAll('#'+id+' .sq-opt').forEach(function(o){o.classList.remove('selected');});}); document.getElementById('sqResult').style.display='none';upProg(1); };
})();
</script>

