<script>
/* ── Fix viewport : anti-zoom iOS + anti-scroll horizontal ── */
(function() {
  var vp = document.querySelector('meta[name="viewport"]');
  if (vp) {
    vp.setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no');
  } else {
    var m = document.createElement('meta');
    m.name = 'viewport';
    m.content = 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no';
    document.head.appendChild(m);
  }
  document.documentElement.style.overflowX = 'hidden';
  document.documentElement.style.maxWidth = '100%';
  document.body && (document.body.style.overflowX = 'hidden');
  document.body && (document.body.style.maxWidth = '100%');
})();
</script>
<script>
function skMenuOpen() {
  document.getElementById('skMenuOverlay').classList.add('open');
  document.getElementById('skMenuDrawer').classList.add('open');
  if (document.getElementById('skMenuBtn')) document.getElementById('skMenuBtn').classList.add('open');
  document.body.style.overflow = 'hidden';
  /* Cacher la bottom nav quand le menu est ouvert */
    if (mob) mob.classList.add('hidden');
}
function skMenuClose() {
  document.getElementById('skMenuOverlay').classList.remove('open');
  document.getElementById('skMenuDrawer').classList.remove('open');
  if (document.getElementById('skMenuBtn')) document.getElementById('skMenuBtn').classList.remove('open');
  document.body.style.overflow = '';
  /* Réafficher la bottom nav */
    if (mob) mob.classList.remove('hidden');
}
</script>

<style>
nav, 
nav.scrolled, 
.nav-logo img { height: 22px; width: auto; display: block; filter: brightness(0) invert(1); }
nav.scrolled .nav-logo img, 
.nav-back { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; color: rgba(255,255,255,0.7); text-decoration: none; text-transform: uppercase; }
