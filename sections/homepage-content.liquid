  font-size: 0.85rem; color: rgba(255,255,255,0.55);
  line-height: 1.6; margin-bottom: 2.4rem; max-width: 380px;
}
.storm-banner-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
.btn-storm-primary {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: #ffffff; color: #0a0a0a; border: none;
  border-radius: 980px; padding: 0.82rem 2rem;
  font-family: var(--font); font-size: 0.78rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
