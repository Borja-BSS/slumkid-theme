}
/* ── SOLD OUT ── */
.sold-out-overlay { position: absolute; inset: 0; z-index: 6; background: rgba(0,0,0,0.52); display: flex; align-items: center; justify-content: center; pointer-events: none; }
.sold-out-label { background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.28); color: #ffffff; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; padding: 0.5rem 1.3rem; border-radius: 980px; }

/* ── RESPONSIVE ── */
.hero { margin-bottom: 0 !important; padding-bottom: 0 !important; }
.products-section { margin-top: 0 !important; padding-top: 0 !important; border-top: none !important; }
@media (max-width: 768px) {
  nav { padding: 0 1.2rem; }
  .nav-links { display: none; }
  /* Anti-zoom iOS : 16px min sur tous les éléments interactifs */
  input, button, select, textarea { font-size: 16px !important; }
  .slide-content { padding: 0 1.5rem 8.5rem; }
  .slide-title { font-size: clamp(3rem, 14vw, 5rem); }
  .carousel-scene { height: 480px; }
  .carousel-ctrl .c-arrow { display: none; }
  .foot-feed-item { flex: 0 0 100px; height: 100px; }
  .foot-legal { flex-direction: column; text-align: center; }
