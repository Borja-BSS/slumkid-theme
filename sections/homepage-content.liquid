<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff !important;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .cs-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 2rem;
    width: 100%;
  }

  .cs-logo {
    width: 200px;
    max-width: 70vw;
    display: block;
  }

  .cs-email-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    max-width: 300px;
  }

  .cs-email-form input[type="email"] {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 1px solid #000;
    background: transparent;
    color: #000;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    outline: none;
    text-align: center;
    -webkit-appearance: none;
    font-family: inherit;
  }

  .cs-email-form input[type="email"]::placeholder {
    color: #aaa;
    letter-spacing: 0.1em;
  }

  .cs-btn {
    width: 100%;
    padding: 0.7rem 1rem;
    background: #000;
    color: #fff;
    border: none;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
  }

  .cs-btn:hover {
    background: #222;
  }

</style>

<div class="cs-wrap">

  <img
    src="{{ 'logo-slumkid.png' | asset_url }}"
    alt="{{ shop.name }}"
    class="cs-logo"
    width="200"
    height="auto"
  />

  <div class="cs-email-form">
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        placeholder="VOTRE EMAIL"
        autocomplete="email"
        required
      />
      <button type="submit" class="cs-btn">REJOINDRE</button>
    {% endform %}
  </div>


</div>

{% schema %}
{
  "name": "Homepage Coming Soon",
  "settings": []
}
{% endschema %}
