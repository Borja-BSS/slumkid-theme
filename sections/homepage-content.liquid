<script>
/* ── Fix viewport ── */
(function() {
  var vp = document.querySelector('meta[name="viewport"]');
  if (vp) { vp.setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no'); }
  else { var m = document.createElement('meta'); m.name='viewport'; m.content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no'; document.head.appendChild(m); }
  document.documentElement.style.overflowX = 'hidden';
  document.documentElement.style.maxWidth = '100%';
  document.body && (document.body.style.overflowX = 'hidden');
})();
</script>

<script>
/* ── BUG CORRIGÉ : mob était jamais déclaré → ReferenceError → page blanche ── */
function skMenuOpen() {
  document.getElementById('skMenuOverlay').classList.add('open');
  document.getElementById('skMenuDrawer').classList.add('open');
  if (document.getElementById('skMenuBtn')) document.getElementById('skMenuBtn').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function skMenuClose() {
  document.getElementById('skMenuOverlay').classList.remove('open');
  document.getElementById('skMenuDrawer').classList.remove('open');
  if (document.getElementById('skMenuBtn')) document.getElementById('skMenuBtn').classList.remove('open');
  document.body.style.overflow = '';
}
</script>

<style>
html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; overflow-x: hidden; max-width: 100%; }
body { overflow-x: hidden; max-width: 100%; }
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --white: #ffffff; --black: #0a0a0a; --gray: #888;
  --light: #f5f5f7;
  --radius-btn: 980px;
  --ease: cubic-bezier(0.4,0,0.2,1);
  --font: -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: var(--font); background: #ffffff; color: #0a0a0a; }

/* ── NAV — transparente au départ, sombre au scroll ── */
nav {
  position: fixed; top: 0; left: 0; width: 100%; z-index: 200; height: 56px;
  background: rgba(10,10,10,0.0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
  border-bottom: 1px solid transparent;
  display: flex; align-items: center; justify-content: space-between; padding: 0 2.4rem;
  transition: background 0.4s, backdrop-filter 0.4s, border-color 0.4s;
}
nav.scrolled {
  background: rgba(10,10,10,0.75);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.nav-logo { display: flex; align-items: center; text-decoration: none; }
.nav-logo img { height: 22px; width: auto; display: block; filter: brightness(0) invert(1); }
@media (min-width: 769px) { .nav-logo img { height: 28px; } }
.nav-links { display: flex; gap: 2.2rem; list-style: none; }
.nav-links a { font-size: 0.72rem; letter-spacing: 0.14em; font-weight: 500; color: rgba(255,255,255,0.7); text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
.nav-links a:hover { color: var(--white); }
.nav-actions { display: flex; gap: 0.8rem; align-items: center; }
.nav-icon-btn { background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.8); transition: color 0.2s; padding: 0.3rem; display: flex; }
.nav-icon-btn:hover { color: var(--white); }

/* ════════ HERO SLIDER ════════ */
.hero { position: relative; width: 100%; height: 100vh; overflow: hidden; }
.hero-track { display: flex; width: 300%; height: 100%; transition: transform 0.9s var(--ease); }
.hero-slide { width: 33.333%; height: 100%; position: relative; flex-shrink: 0; display: flex; align-items: flex-end; }
.hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center top; }
.hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.45) 40%, rgba(0,0,0,0.1) 70%, transparent 100%); }
.slide-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 0 3.5rem 4.5rem; opacity: 0; transform: translateY(28px); transition: opacity 0.8s 0.25s var(--ease), transform 0.8s 0.25s var(--ease); }
.hero-slide.active .slide-content { opacity: 1; transform: translateY(0); }
.slide-eyebrow { font-size: 0.65rem; letter-spacing: 0.22em; font-weight: 500; color: rgba(255,255,255,0.55); text-transform: uppercase; display: block; margin-bottom: 0.9rem; }
.slide-title { font-size: clamp(4rem, 10vw, 9rem); font-weight: 900; letter-spacing: -0.03em; line-height: 0.92; color: var(--white); text-transform: uppercase; margin-bottom: 1.2rem; }
.slide-body { font-size: 0.88rem; color: rgba(255,255,255,0.7); line-height: 1.6; letter-spacing: 0.02em; margin-bottom: 2rem; max-width: 480px; }
.slide-cta-row { display: flex; gap: 0.8rem; flex-wrap: wrap; align-items: center; }
.btn-primary { display: inline-flex; align-items: center; gap: 0.35rem; background: #ffffff; color: #0a0a0a; border: none; border-radius: var(--radius-btn); padding: 0.72rem 1.6rem; font-family: var(--font); font-size: 0.82rem; font-weight: 600; letter-spacing: -0.01em; cursor: pointer; text-decoration: none; transition: opacity 0.2s, transform 0.15s; }
.btn-primary:hover { opacity: 0.88; transform: scale(0.98); }
.hero-dots { position: absolute; bottom: 2.4rem; right: 2.8rem; display: flex; gap: 8px; z-index: 10; align-items: center; }
.hero-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.3); cursor: pointer; border: none; transition: all 0.35s; }
.hero-dot.active { background: var(--white); transform: scale(1.2); }

/* ════════ STORM BANNER ════════ */
.storm-banner { position: relative; width: 100%; height: 70vh; overflow: hidden; display: flex; align-items: center; }
.storm-banner-bg { position: absolute; inset: 0; background-size: cover; background-position: center 30%; background-image: url('{{ "slide-banner-clean.jpg" | asset_url }}'); }
.storm-banner-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.2) 100%); }
.storm-banner-content { position: absolute; z-index: 2; bottom: 2.5rem; left: 0; right: 0; padding: 0 2rem; text-align: right; display: flex; flex-direction: column; align-items: flex-end; }
.storm-banner-eyebrow { font-size: 0.6rem; letter-spacing: 0.3em; font-weight: 600; color: rgba(255,255,255,0.45); text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem; }
.storm-banner-eyebrow::before { content: ''; width: 30px; height: 1px; background: rgba(255,255,255,0.3); }
.storm-banner-title { font-size: clamp(3rem, 7vw, 7rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.88; text-transform: uppercase; color: #ffffff; margin-bottom: 1.4rem; }
.storm-banner-sub { font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin-bottom: 2.4rem; max-width: 380px; }
.storm-banner-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
.btn-storm-primary { display: inline-flex; align-items: center; gap: 0.4rem; background: #ffffff; color: #0a0a0a; border: none; border-radius: 980px; padding: 0.82rem 2rem; font-family: var(--font); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: opacity 0.2s; }
.btn-storm-primary:hover { opacity: 0.88; }
.btn-storm-ghost { display: inline-flex; align-items: center; background: transparent; color: #ffffff; border: 1px solid rgba(255,255,255,0.45); border-radius: 980px; padding: 0.82rem 2rem; font-family: var(--font); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: all 0.2s; }
.btn-storm-ghost:hover { background: rgba(255,255,255,0.1); border-color: #ffffff; }

/* ════════ CAROUSEL PRODUITS ════════ */
.products-section { background: #f5f5f7; padding: 0; }
.carousel-header { display: flex; align-items: baseline; justify-content: space-between; padding: 3.2rem 2.4rem 2rem; }
.carousel-title { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase; }
.carousel-sub { font-size: 0.65rem; letter-spacing: 0.15em; color: rgba(0,0,0,0.45); text-transform: uppercase; font-weight: 500; }
.carousel-scene { position: relative; overflow: hidden; width: 100%; height: 520px; }
.carousel-track { display: flex; height: 100%; gap: 0; transition: transform 0.7s var(--ease); cursor: grab; user-select: none; }
.carousel-track:active { cursor: grabbing; }
.c-card { flex: 0 0 calc(100% / 3); height: 100%; position: relative; overflow: hidden; }
.c-card-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; transition: transform 0.7s var(--ease); }
.c-card:hover .c-card-img { transform: scale(1.04); }
.c-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.35) 45%, transparent 75%); }
.c-card-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem 1.4rem 1.6rem; z-index: 5; }
.c-card-col { font-size: 0.48rem; letter-spacing: 0.28em; font-weight: 700; text-transform: uppercase; color: rgba(255,255,255,0.45); display: block; margin-bottom: 0.4rem; }
.c-card-name { font-size: clamp(1.1rem, 2vw, 1.5rem); font-weight: 900; letter-spacing: -0.02em; color: var(--white); text-transform: uppercase; line-height: 1.0; }
.c-card-price { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.65); margin-top: 0.4rem; }
.c-card-price.sold { text-decoration: line-through; color: rgba(255,255,255,0.35); }
.carousel-ctrl { display: flex; align-items: center; justify-content: flex-end; padding: 1.4rem 2.4rem 2.8rem; gap: 0.6rem; }
.c-arrow { background: #0a0a0a; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #fff; transition: opacity 0.2s; }
.c-arrow:hover { opacity: 0.7; }
.sold-out-overlay { position: absolute; inset: 0; z-index: 6; background: rgba(0,0,0,0.52); display: flex; align-items: center; justify-content: center; pointer-events: none; }
.sold-out-label { background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.28); color: #ffffff; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; padding: 0.5rem 1.3rem; border-radius: 980px; }

/* ════════ SLOGANS ════════ */
.slogan-section { background: #f5f5f7; padding: 4rem 2rem; display: flex; align-items: center; justify-content: center; min-height: 28vh; }
.slogan-inner { text-align: center; max-width: 900px; }
.slogan-label { font-size: 0.65rem; letter-spacing: 0.22em; font-weight: 500; color: rgba(0,0,0,0.45); text-transform: uppercase; display: block; margin-bottom: 1.8rem; }
.slogan-text { font-size: clamp(2.2rem, 5vw, 4.5rem); font-weight: 900; letter-spacing: -0.03em; line-height: 1.05; color: var(--black); text-transform: uppercase; min-height: 1.2em; }
.slogan-cursor { display: inline-block; width: 3px; height: 0.85em; background: var(--black); margin-left: 4px; vertical-align: middle; animation: blink 0.75s step-end infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

/* ════════ FOOTER ════════ */
.site-footer { background: #ffffff; border-top: 1px solid rgba(0,0,0,0.07); }
.foot-main { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 3rem; padding: 4rem 2.4rem 3rem; }
.foot-brand { display: flex; flex-direction: column; gap: 1rem; }
.foot-logo-img { height: 24px; width: auto; filter: brightness(0); }
.foot-tagline { font-size: 0.78rem; color: rgba(0,0,0,0.5); line-height: 1.7; max-width: 260px; }
.foot-social-row { display: flex; gap: 0.8rem; margin-top: 0.5rem; }
.foot-social { width: 32px; height: 32px; border-radius: 50%; background: rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center; color: rgba(0,0,0,0.6); text-decoration: none; transition: background 0.2s, color 0.2s; }
.foot-social:hover { background: #0a0a0a; color: #fff; }
.foot-col-title { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(0,0,0,0.35); margin-bottom: 1.2rem; }
.foot-links { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
.foot-links a { font-size: 0.82rem; color: rgba(0,0,0,0.65); text-decoration: none; transition: color 0.2s; }
.foot-links a:hover { color: #0a0a0a; }
.foot-feed { display: grid; grid-template-columns: repeat(5, 1fr); gap: 4px; padding: 0 2.4rem; }
.foot-feed-item { aspect-ratio: 1; overflow: hidden; background: rgba(0,0,0,0.06); }
.foot-feed-item img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(20%); transition: filter 0.3s; }
.foot-feed-item:hover img { filter: grayscale(0%); }
.foot-legal { display: flex; align-items: center; justify-content: space-between; padding: 1.4rem 2.4rem; border-top: 1px solid rgba(0,0,0,0.06); gap: 1rem; flex-wrap: wrap; }
.foot-copy { font-size: 0.62rem; color: rgba(0,0,0,0.5); letter-spacing: 0.02em; white-space: normal; word-break: break-word; }
.foot-legal-links { display: flex; flex-wrap: wrap; gap: 1.4rem; align-items: center; justify-content: center; }
.foot-legal-links a { font-size: 0.68rem; color: rgba(0,0,0,0.55); text-decoration: none; letter-spacing: 0.04em; transition: color 0.2s; }
.foot-legal-links a:hover { color: #0a0a0a; }

/* ════════ MENU HAMBURGER ════════ */
.sk-menu-btn { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; gap: 5px; padding: 6px; z-index: 310; }
.sk-menu-btn span { display: block; width: 22px; height: 1.5px; background: currentColor; transition: all 0.3s; color: inherit; }
.sk-menu-btn.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.sk-menu-btn.open span:nth-child(2) { opacity: 0; }
.sk-menu-btn.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.sk-menu-overlay { position: fixed; inset: 0; z-index: 299; background: rgba(0,0,0,0.3); backdrop-filter: blur(4px); opacity: 0; pointer-events: none; transition: opacity 0.35s; }
.sk-menu-overlay.open { opacity: 1; pointer-events: all; }
.sk-menu-drawer { position: fixed; top: 0; right: 0; bottom: 0; z-index: 300; width: min(360px, 88vw); background: #ffffff; display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); box-shadow: -8px 0 40px rgba(0,0,0,0.12); }
.sk-menu-drawer.open { transform: translateX(0); }
.sk-menu-header { display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 1.6rem; border-bottom: 1px solid rgba(0,0,0,0.08); }
.sk-menu-close { background: rgba(0,0,0,0.06); border: none; width: 34px; height: 34px; border-radius: 50%; cursor: pointer; color: #0a0a0a; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
.sk-menu-close:hover { background: rgba(0,0,0,0.12); }
.sk-menu-links { flex: 1; display: flex; flex-direction: column; padding: 1.5rem 1.6rem; gap: 0; }
.sk-menu-link { display: flex; flex-direction: column; gap: 0.15rem; font-size: 1.8rem; font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase; color: #0a0a0a; text-decoration: none; line-height: 1.0; padding: 0.9rem 0; border-bottom: 1px solid rgba(0,0,0,0.07); opacity: 0; transform: translateX(20px); transition: opacity 0.4s, transform 0.4s, color 0.2s; }
.sk-menu-drawer.open .sk-menu-link { opacity: 1; transform: translateX(0); }
.sk-menu-drawer.open .sk-menu-link:nth-child(1) { transition-delay: 0.05s; }
.sk-menu-drawer.open .sk-menu-link:nth-child(2) { transition-delay: 0.10s; }
.sk-menu-drawer.open .sk-menu-link:nth-child(3) { transition-delay: 0.15s; }
.sk-menu-drawer.open .sk-menu-link:nth-child(4) { transition-delay: 0.20s; }
.sk-menu-link:last-child { border-bottom: none; }
.sk-menu-link:hover { color: rgba(0,0,0,0.45); }
.sk-menu-sub { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.2em; color: rgba(0,0,0,0.3); text-transform: uppercase; display: block; margin-bottom: 0.1rem; }
.sk-menu-footer { padding: 1.6rem; border-top: 1px solid rgba(0,0,0,0.07); display: flex; flex-direction: column; gap: 1rem; }
.sk-menu-socials { display: flex; gap: 1.2rem; align-items: center; }
.sk-menu-social { color: rgba(0,0,0,0.45); transition: color 0.2s; display: flex; text-decoration: none; }
.sk-menu-social:hover { color: #0a0a0a; }
.sk-menu-copy { font-size: 0.55rem; color: rgba(0,0,0,0.25); letter-spacing: 0.06em; }

/* ════════ RESPONSIVE ════════ */
.hero { margin-bottom: 0 !important; padding-bottom: 0 !important; }
.products-section { margin-top: 0 !important; padding-top: 0 !important; border-top: none !important; }
@media (max-width: 768px) {
  nav { padding: 0 1.2rem; }
  .nav-links { display: none; }
  input, button, select, textarea { font-size: 16px !important; }
  .slide-content { padding: 0 1.5rem 8.5rem; }
  .slide-title { font-size: clamp(3rem, 14vw, 5rem); }
  .carousel-scene { height: 480px; }
  .c-card { flex: 0 0 80vw; }
  .c-arrow { display: none; }
  .foot-main { grid-template-columns: 1fr 1fr; gap: 2rem; padding: 3rem 1.5rem 2rem; }
  .foot-legal { flex-direction: column; text-align: center; }
  .foot-legal-links { justify-content: center; }
  .storm-banner { height: 100vw; }
  .storm-banner-content { bottom: 1.8rem; padding: 0 1.5rem; }
}
</style>

