<script>
/* ── SCROLL NAV ── */
window.addEventListener('scroll', function() {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 40);
});

/* ── HERO SLIDER ── */
var heroIdx = 0;
var heroTotal = 3;
var heroTimer;

function heroGoTo(idx) {
  document.getElementById('slide' + heroIdx).classList.remove('active');
  document.querySelectorAll('.hero-dot')[heroIdx].classList.remove('active');
  heroIdx = idx;
  document.getElementById('heroTrack').style.transform = 'translateX(-' + (heroIdx * 33.333) + '%)';
  document.getElementById('slide' + heroIdx).classList.add('active');
  document.querySelectorAll('.hero-dot')[heroIdx].classList.add('active');
}

function heroNext() { heroGoTo((heroIdx + 1) % heroTotal); }
function heroPrev() { heroGoTo((heroIdx - 1 + heroTotal) % heroTotal); }

function heroAutoPlay() {
  clearInterval(heroTimer);
  heroTimer = setInterval(heroNext, 5000);
}
heroAutoPlay();

/* Touch swipe hero */
(function() {
  var el = document.getElementById('heroSlider');
  var sx = 0;
  el.addEventListener('touchstart', function(e) { sx = e.touches[0].clientX; }, { passive: true });
  el.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 40) { dx < 0 ? heroNext() : heroPrev(); heroAutoPlay(); }
  });
})();

/* ── CAROUSEL ── */
(function() {
  var track = document.getElementById('carouselTrack');
  var scene = document.getElementById('carouselScene');
  var cards = track.querySelectorAll('.c-card');
  var idx = 0;
  var cardW = 0;
  var visible = 3;

  function resize() {
    var w = scene.offsetWidth;
    visible = w < 600 ? 1 : w < 900 ? 2 : 3;
    cardW = w / visible;
    cards.forEach(function(c) { c.style.flex = '0 0 ' + cardW + 'px'; });
    goTo(idx);
  }

  function goTo(n) {
    var max = Math.max(0, cards.length - visible);
    idx = Math.max(0, Math.min(n, max));
    track.style.transform = 'translateX(-' + (idx * cardW) + 'px)';
  }

  document.getElementById('cNext').addEventListener('click', function() { goTo(idx + 1); });
  document.getElementById('cPrev').addEventListener('click', function() { goTo(idx - 1); });

  /* Touch swipe */
  var sx = 0;
  track.addEventListener('touchstart', function(e) { sx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 30) { dx < 0 ? goTo(idx + 1) : goTo(idx - 1); }
  });

  window.addEventListener('resize', resize);
  resize();
})();

/* ── TYPEWRITER SLOGANS ── */
(function() {
  var slogans = ['FROM SLUM TO FASHION', 'LA DALLE DES BIDONVILLES', 'ON FORCE PERSONNE', 'BE PART OF IT'];
  var el = document.getElementById('sloganText');
  if (!el) return;
  var si = 0, ci = 0, deleting = false;
  var cursor = '<span class="slogan-cursor"></span>';

  function type() {
    var s = slogans[si];
    if (!deleting) {
      ci++;
      el.innerHTML = s.slice(0, ci) + cursor;
      if (ci === s.length) { deleting = true; setTimeout(type, 2200); return; }
      setTimeout(type, 55);
    } else {
      ci--;
      el.innerHTML = s.slice(0, ci) + cursor;
      if (ci === 0) { deleting = false; si = (si + 1) % slogans.length; setTimeout(type, 400); return; }
      setTimeout(type, 28);
    }
  }
  setTimeout(type, 800);
})();
</script>

