<script>
/* ── SCROLL : nav + bottom nav ── */
window.addEventListener('scroll', function() {
  var scrolled = window.scrollY > 40;
  var mainNav = document.getElementById('mainNav');
  if (mainNav) mainNav.classList.toggle('scrolled', scrolled);
  var mob = document.getElementById('mobNav');
  if (mob) mob.classList.toggle('scrolled', scrolled);
});

/* ── BUG CORRIGÉ #3 : logo devient noir au scroll ── */
window.addEventListener('scroll', function() {
  var logo = document.querySelector('#mainNav .nav-logo img');
  if (!logo) return;
  if (window.scrollY > 40) {
    logo.style.filter = 'brightness(0)';
  } else {
    logo.style.filter = 'brightness(0) invert(1)';
  }
});

/* ── HERO SLIDER ── */
const DURATION = 5500;
const hSlides = document.querySelectorAll('.hero-slide');
const hDots   = document.querySelectorAll('.hero-dot');
const hTrack  = document.getElementById('heroTrack');
const hProg   = document.getElementById('heroProgress');
let hCur = 0, hTimer, hStart, hRaf;

function hGo(n) {
  hSlides[hCur].classList.remove('active'); hDots[hCur].classList.remove('active');
  hCur = ((n % hSlides.length) + hSlides.length) % hSlides.length;
  hSlides[hCur].classList.add('active'); hDots[hCur].classList.add('active');
  hTrack.style.transform = 'translateX(-' + (hCur * 33.333) + '%)';
}
function hProgress() {
  cancelAnimationFrame(hRaf); hProg.style.transition = 'none'; hProg.style.width = '0%';
  hStart = performance.now();
  (function tick(now) {
    var p = Math.min((now - hStart) / DURATION * 100, 100);
    hProg.style.width = p + '%';
    if (p < 100) hRaf = requestAnimationFrame(tick);
  })(hStart);
}
function hAuto() { clearInterval(hTimer); hProgress(); hTimer = setInterval(function() { hGo(hCur + 1); hProgress(); }, DURATION); }

hDots.forEach(function(d) { d.addEventListener('click', function() { clearInterval(hTimer); hGo(+d.dataset.i); hAuto(); }); });
var htx = 0;
document.querySelector('.hero').addEventListener('touchstart', function(e) { htx = e.touches[0].clientX; }, { passive: true });
document.querySelector('.hero').addEventListener('touchend', function(e) {
  var dx = e.changedTouches[0].clientX - htx;
  if (Math.abs(dx) > 50) { clearInterval(hTimer); hGo(dx < 0 ? hCur + 1 : hCur - 1); hAuto(); }
});
hAuto();

/* ── CAROUSEL ── */
(function () {
  var scene     = document.getElementById('carouselScene');
  var inner     = document.getElementById('carouselInner');
  var origCards = Array.from(document.querySelectorAll('.p-card'));
  var ptotal    = origCards.length;
  var pDots     = document.getElementById('cDots');
  var CLONE     = 3;

  for (var i = 0; i < CLONE; i++) {
    origCards.forEach(function(c) { var cl = c.cloneNode(true); cl.setAttribute('data-clone', '1'); inner.appendChild(cl); });
  }
  for (var i = 0; i < CLONE; i++) {
    origCards.slice().reverse().forEach(function(c) { var cl = c.cloneNode(true); cl.setAttribute('data-clone', '1'); inner.prepend(cl); });
  }

  var allCards = Array.from(inner.querySelectorAll('.p-card'));
  var total    = allCards.length;
  var pActive  = CLONE * ptotal;

  origCards.forEach(function(_, i) {
    var d = document.createElement('button');
    d.className = 'c-dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', function() { pGo(CLONE * ptotal + i); });
    pDots.appendChild(d);
  });

  function updateDots() {
    var origIdx = ((pActive - CLONE * ptotal) % ptotal + ptotal) % ptotal;
    document.querySelectorAll('.c-dot').forEach(function(d, i) { d.classList.toggle('active', i === origIdx); });
  }

  function applyClasses() {
    var L  = (pActive - 1 + total) % total;
    var R  = (pActive + 1) % total;
    var FL = (pActive - 2 + total) % total;
    var FR = (pActive + 2) % total;
    allCards.forEach(function(c, i) {
      c.className = 'p-card';
      if      (i === pActive) c.classList.add('pos-center');
      else if (i === L)       c.classList.add('pos-left');
      else if (i === R)       c.classList.add('pos-right');
      else if (i === FL)      c.classList.add('pos-far-left');
      else if (i === FR)      c.classList.add('pos-far-right');
      else                    c.classList.add('pos-hidden');
    });
  }

  function slide(animated) {
    inner.style.transition = animated ? 'transform 0.7s cubic-bezier(0.4,0,0.2,1)' : 'none';
    inner.style.transform  = 'translateX(-' + (pActive * 33.333 - 33.333) + '%)';
  }

  function pGo(idx, animated) {
    if (animated === undefined) animated = true;
    pActive = idx;
    applyClasses(); slide(animated); updateDots();
    inner.addEventListener('transitionend', function onEnd() {
      inner.removeEventListener('transitionend', onEnd);
      if (pActive < CLONE * ptotal)              { pActive += ptotal; slide(false); applyClasses(); }
      else if (pActive >= (CLONE + 1) * ptotal)  { pActive -= ptotal; slide(false); applyClasses(); }
    });
  }

  document.getElementById('cPrev').onclick = function() { pGo(pActive - 1); };
  document.getElementById('cNext').onclick = function() { pGo(pActive + 1); };

  var ctx = 0;
  scene.addEventListener('touchstart', function(e) { ctx = e.touches[0].clientX; }, { passive: true });
  scene.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - ctx;
    if (Math.abs(dx) > 45) pGo(dx < 0 ? pActive + 1 : pActive - 1);
  });

  var autoTimer = setInterval(function() { pGo(pActive + 1); }, 3500);
  scene.addEventListener('touchstart', function() { clearInterval(autoTimer); }, { passive: true });

  pGo(pActive, false);
})();

/* ── TYPEWRITER SLOGANS ── */
(function () {
  var slogans = ['FROM SLUM TO FASHION','WEAR WHAT YOU ARE','BE PART OF IT','NEW DROP — SEASON 26','SLUM LIFE'];
  var el = document.getElementById('sloganText');
  var si = 0, ci = 0, deleting = false;
  var SPEED_TYPE = 80, SPEED_DEL = 40, PAUSE = 2200;
  function tick() {
    var word = slogans[si];
    if (!deleting) {
      ci++;
      el.innerHTML = word.slice(0, ci) + '<span class="slogan-cursor"></span>';
      if (ci === word.length) { deleting = true; setTimeout(tick, PAUSE); return; }
    } else {
      ci--;
      el.innerHTML = word.slice(0, ci) + '<span class="slogan-cursor"></span>';
      if (ci === 0) { deleting = false; si = (si + 1) % slogans.length; }
    }
    setTimeout(tick, deleting ? SPEED_DEL : SPEED_TYPE);
  }
  setTimeout(tick, 600);
})();
</script>

