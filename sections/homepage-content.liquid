.sk-menu-btn span { background: #ffffff; transition: background 0.4s; }

body { overflow-x: hidden; max-width: 100%; }

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --white:  #ffffff;
  --black:  #0a0a0a;
  --gray:   #888;
  --light:  #f5f5f7;
  --radius-btn: 980px;
